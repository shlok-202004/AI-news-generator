# Copy this file to .env and fill in your values

# AI Provider — "openrouter" or "gemini"
AI_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# GNews (https://gnews.io — free tier: 100 req/day)
GNEWS_API_KEY=your-gnews-key

# Discord webhook URL (for scheduled briefing via webhook)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord bot (required only for slash commands)
# Get token at: discord.com/developers → Your App → Bot → Token
DISCORD_BOT_TOKEN=your-bot-token

# Discord channel ID where the daily briefing is posted by the bot
# Right-click a channel in Discord → Copy Channel ID (enable Developer Mode first)
DISCORD_CHANNEL_ID=your-channel-id

# Your Discord server (guild) ID — enables INSTANT slash command sync
# Right-click your server icon in Discord → Copy Server ID (Developer Mode must be on)
DISCORD_GUILD_ID=your-server-id

# Optional: minutes /news serves a cached briefing before regenerating (default 30, 0 disables)
BRIEFING_CACHE_TTL_MINUTES=30

# ── Cloud deployment (Fly.io) ──────────────────────────────────────────────────
# On Fly.io, set this secret so SQLite writes to the persistent volume:
#   fly secrets set DB_PATH=/data/seen_articles.db
# Leave unset for local development — db/seen_articles.db is used by default.
# DB_PATH=/data/seen_articles.db
